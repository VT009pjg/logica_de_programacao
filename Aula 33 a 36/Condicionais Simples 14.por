programa {
  funcao inicio() {
  inteiro valor1, valor2

  escreva("Digite o Primeiro Valor: ")
  leia(valor1)  

  escreva("Digite o Segundo Valor: ")
  leia(valor2)

  se ( valor1 > valor2){
  escreva("Valor 1 é Maior")
  } senao se (valor1 < valor2){
    escreva("Valor 2 é Maior")
  } senao se (valor1 == valor2){
    escreva("Valor 1 é Igual a Valor 2")
  }
  
  }
}
