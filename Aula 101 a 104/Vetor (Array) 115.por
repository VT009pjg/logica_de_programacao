programa {
  funcao inicio() {
   inteiro vetor[4]
   inteiro soma, multiplicacao, diferenca

   vetor[0] = 5
   vetor[1] = 2
   vetor[2] = 4
   vetor[3] = 10

   soma = vetor[0] + vetor[3]
   multiplicacao = vetor[1] * vetor[2]
   diferenca = vetor[2] - vetor[0]

   escreva("Soma: ", soma, "\n")
   escreva("Multiplicação: ", multiplicacao, "\n")
   escreva("Diferença: ", diferenca)
  }
}
