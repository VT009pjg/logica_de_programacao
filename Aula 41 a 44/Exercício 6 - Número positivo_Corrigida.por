programa
{
    funcao inicio()
    {
        inteiro numero

        escreva("Digite um Número: ")   // falta o escreva pois fica dificil para interpretar
        leia(numero)

        se (numero <= 0)   //um, erro na condicao por que se o numero digitado for 0 ele ainda e positivo
        {
            escreva("Numero positivo")
        }       
    }
}