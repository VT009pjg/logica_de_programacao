programa
{
    funcao inicio()
    {
        real n1, n2, media

        escreva("Digite a Primeira nota: ")   // falta o escreva pois fica dificil para interpretar

         leia(n1)

        escreva("Digite a Segunda Nota: ")   // falta o escreva pois fica dificil para interpretar

         leia(n2)

        media = (n1 + n2) / 2   // e esta dividindo por 3 ao inves do 2
        

        escreva("Média: ", media)
    }
}