programa
{
    funcao inicio()
    {
        inteiro largura, altura
        real area

        escreva("Digite a Largura: " ) // falta o escreva pois fica dificil para interpretar
         leia(largura)
        
        escreva("Digite a Altura: ") // falta o escreva pois fica dificil para interpretar
         leia(altura)

        area = largura * altura

        escreva("Área: ", area)

       
    }
}